// ── Distinct values for filter dropdowns ──────────
export async function handleDistincts(_req: Request, res: Response) {
  try {
    const pg = getPool()
    const sql = `
      SELECT 'clewdr_models' AS k, array_agg(DISTINCT model ORDER BY model) AS v
        FROM clewdr_logs WHERE model IS NOT NULL AND created_at > now() - interval '30 days'
      UNION ALL
      SELECT 'oai_models',         array_agg(DISTINCT model ORDER BY model)
        FROM oai_logs    WHERE model IS NOT NULL AND created_at > now() - interval '30 days'
      UNION ALL
      SELECT 'clewdr_client_types', array_agg(DISTINCT client_type ORDER BY client_type)
        FROM clewdr_logs WHERE client_type IS NOT NULL AND created_at > now() - interval '30 days'
      UNION ALL
      SELECT 'oai_client_types',    array_agg(DISTINCT client_type ORDER BY client_type)
        FROM oai_logs    WHERE client_type IS NOT NULL AND created_at > now() - interval '30 days'
      UNION ALL
      SELECT 'clewdr_cookies',      array_agg(DISTINCT cookie_short ORDER BY cookie_short)
        FROM clewdr_logs WHERE cookie_short IS NOT NULL AND created_at > now() - interval '30 days'
    `
    const r = await pg.query(sql)
    const out: any = {}
    for (const row of r.rows) out[row.k] = row.v || []
    res.json({ status: "Success", data: out })
  } catch (e: any) {
    res.status(500).json({ status: "Fail", message: e.message })
  }
}

// ── Settings (retention) ──────────────────────────
export async function handleGetSettings(_req: Request, res: Response) {
  try {
    const pg = getPool()
    const r = await pg.query(`SELECT key, value FROM audit_config`)
    const cfg: any = {}
    for (const row of r.rows) cfg[row.key] = row.value
    res.json({ status: "Success", data: cfg })
  } catch (e: any) {
    res.status(500).json({ status: "Fail", message: e.message })
  }
}

export async function handleUpdateSettings(req: Request, res: Response) {
  try {
    const updates = req.body as Record<string, string>
    const pg = getPool()
    const allowed = new Set([
      "retention_days_clewdr",
      "retention_days_oai",
      "enabled_clewdr",
      "enabled_oai",
      "max_body_kb",
    ])
    for (const [k, v] of Object.entries(updates)) {
      if (!allowed.has(k)) continue
      await pg.query(
        `INSERT INTO audit_config (key, value, updated_at) VALUES ($1, $2, NOW())
         ON CONFLICT (key) DO UPDATE SET value = EXCLUDED.value, updated_at = NOW()`,
        [k, String(v)],
      )
    }
    res.json({ status: "Success" })
  } catch (e: any) {
    res.status(500).json({ status: "Fail", message: e.message })
  }
}

