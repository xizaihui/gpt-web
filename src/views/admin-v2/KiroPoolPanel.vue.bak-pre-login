<script setup lang="ts">
import { ref, computed, onMounted, onBeforeUnmount } from 'vue'
import { fetchKiroUsage, fetchKiroHistory, refreshKiroQuotas, disableKiroAccount, enableKiroAccount, testKiroAccount } from '@/api'
import Icon from '@/components/common/Icon.vue'

interface KiroAccount {
  id: string
  source: string
  ok: boolean
  auth_type?: string
  subscription?: { title?: string; type?: string; overage_capability?: string }
  limit?: number
  used?: number
  remaining?: number
  percent?: number
  unit?: string
  overage?: { status?: string; used?: number; cap?: number; rate?: number; currency?: string; charges?: number }
  free_trial?: { status?: string; used?: number; limit?: number; expiry?: number } | null
  days_until_reset?: number
  next_date_reset?: number
  disabled?: boolean
  active_sessions?: number
  total_requests?: number
  error?: string
}

interface UsageResponse {
  accounts: KiroAccount[]
  total: number
  summary: {
    ok_count: number
    error_count: number
    total_limit: number
    total_used: number
    total_remaining: number
    percent: number
    unit: string
    free_trial_used: number
    free_trial_limit: number
  }
}

const usage = ref<UsageResponse | null>(null)
const history = ref<{ series: any[]; latest: any[]; bucket_seconds: number; hours: number } | null>(null)
const loading = ref(false)
const refreshing = ref(false)
const historyHours = ref<number>(24)
const selectedAccountId = ref<string>('all')
const autoRefreshTimer = ref<number | null>(null)

async function loadUsage() {
  loading.value = true
  try {
    const res: any = await fetchKiroUsage(false)
    usage.value = res
  }
  catch (e: any) { console.error('fetchKiroUsage error:', e) }
  finally { loading.value = false }
}

async function loadHistory() {
  try {
    const params: any = { hours: historyHours.value }
    if (selectedAccountId.value !== 'all') params.accountId = selectedAccountId.value
    history.value = await fetchKiroHistory(params)
  }
  catch (e: any) { console.error('fetchKiroHistory error:', e) }
}

async function forceRefresh() {
  refreshing.value = true
  try {
    await refreshKiroQuotas()
    await Promise.all([loadUsage(), loadHistory()])
  }
  catch (e: any) { alert(e?.message || '刷新失败') }
  finally { refreshing.value = false }
}

async function handleToggleDisable(acct: KiroAccount) {
  try {
    if (acct.disabled) await enableKiroAccount(acct.id)
    else await disableKiroAccount(acct.id)
    await loadUsage()
  }
  catch (e: any) { alert(e?.message || '操作失败') }
}

async function handleTestAccount(acct: KiroAccount) {
  try {
    const r: any = await testKiroAccount(acct.id)
    if (r?.token_valid) alert(`✅ ${acct.id} token 有效`)
    else alert(`❌ ${acct.id} 测试失败: ${r?.error || '未知错误'}`)
  }
  catch (e: any) { alert(e?.message || '测试失败') }
}

const accounts = computed(() => usage.value?.accounts || [])
const summary = computed(() => usage.value?.summary)

const healthyCount = computed(() => accounts.value.filter(a => a.ok && !a.disabled && (a.percent || 0) < 90).length)
const warningCount = computed(() => accounts.value.filter(a => a.ok && !a.disabled && (a.percent || 0) >= 90 && (a.percent || 0) < 98).length)
const criticalCount = computed(() => accounts.value.filter(a => a.ok && !a.disabled && (a.percent || 0) >= 98).length)
const disabledCount = computed(() => accounts.value.filter(a => a.disabled).length)

function resetCountdown(nextReset?: number) {
  if (!nextReset) return '—'
  const delta = nextReset - Math.floor(Date.now() / 1000)
  if (delta <= 0) return '刚刚重置'
  const days = Math.floor(delta / 86400)
  const hours = Math.floor((delta % 86400) / 3600)
  if (days > 0) return `${days} 天 ${hours} 小时`
  const mins = Math.floor((delta % 3600) / 60)
  return `${hours} 小时 ${mins} 分`
}

function subBadgeClass(title?: string) {
  if (!title) return 'bg-[#f4f4f5] text-[#71717a] border-[#e5e7eb]'
  if (title.includes('POWER')) return 'bg-[#fef3c7] text-[#b45309] border-[#fde68a]'
  if (title.includes('PRO')) return 'bg-[#dbeafe] text-[#1d4ed8] border-[#bfdbfe]'
  return 'bg-[#f4f4f5] text-[#71717a] border-[#e5e7eb]'
}

function percentColor(pct: number) {
  if (pct >= 98) return '#dc2626'
  if (pct >= 90) return '#d97706'
  if (pct >= 70) return '#ca8a04'
  return '#16a34a'
}

// Trend chart
const accountColors: Record<string, string> = {}
const palette = ['#2563eb', '#dc2626', '#16a34a', '#d97706', '#7c3aed', '#0891b2', '#ea580c', '#059669']
function colorForAccount(id: string) {
  if (!accountColors[id]) {
    const used = Object.keys(accountColors).length
    accountColors[id] = palette[used % palette.length]
  }
  return accountColors[id]
}

interface ChartSeries {
  accountId: string
  color: string
  points: { ts: number; value: number; used: number; limit: number }[]
}

const chartSeries = computed<ChartSeries[]>(() => {
  if (!history.value?.series) return []
  const byAcct: Record<string, ChartSeries> = {}
  for (const row of history.value.series) {
    const id = row.account_id
    if (!byAcct[id])
      byAcct[id] = { accountId: id, color: colorForAccount(id), points: [] }
    byAcct[id].points.push({ ts: row.ts, value: (row.fraction || 0) * 100, used: row.used, limit: row.usage_limit })
  }
  return Object.values(byAcct).sort((a, b) => a.accountId.localeCompare(b.accountId))
})

const chartBox = { w: 820, h: 200, padLeft: 40, padRight: 20, padTop: 16, padBottom: 24 }
function chartXY(p: { ts: number; value: number }, tsMin: number, tsMax: number) {
  const { w, h, padLeft, padRight, padTop, padBottom } = chartBox
  const innerW = w - padLeft - padRight
  const innerH = h - padTop - padBottom
  const tsRange = Math.max(1, tsMax - tsMin)
  const x = padLeft + ((p.ts - tsMin) / tsRange) * innerW
  const y = padTop + (1 - Math.min(1, Math.max(0, p.value / 100))) * innerH
  return { x, y }
}

function seriesPath(s: ChartSeries, tsMin: number, tsMax: number) {
  return s.points.map((p, i) => {
    const { x, y } = chartXY(p, tsMin, tsMax)
    return `${i === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)}`
  }).join(' ')
}

const chartTsRange = computed(() => {
  const all = chartSeries.value.flatMap(s => s.points.map(p => p.ts))
  if (all.length < 2) return null
  return { min: Math.min(...all), max: Math.max(...all) }
})

function fmtTick(ts: number) {
  const d = new Date(ts * 1000)
  if (historyHours.value <= 24) return d.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', hour12: false })
  if (historyHours.value <= 24 * 7) return `${d.getMonth() + 1}/${d.getDate()} ${String(d.getHours()).padStart(2, '0')}:00`
  return `${d.getMonth() + 1}/${d.getDate()}`
}

const xTicks = computed<{ ts: number; x: number; label: string }[]>(() => {
  const r = chartTsRange.value
  if (!r) return []
  const TICK_COUNT = 5
  const ticks: { ts: number; x: number; label: string }[] = []
  for (let i = 0; i < TICK_COUNT; i++) {
    const ts = r.min + ((r.max - r.min) * i) / (TICK_COUNT - 1)
    const { x } = chartXY({ ts, value: 0 }, r.min, r.max)
    ticks.push({ ts, x, label: fmtTick(ts) })
  }
  return ticks
})

onMounted(async () => {
  await Promise.all([loadUsage(), loadHistory()])
  autoRefreshTimer.value = window.setInterval(() => { loadUsage() }, 60_000)
})

onBeforeUnmount(() => {
  if (autoRefreshTimer.value) clearInterval(autoRefreshTimer.value)
})
</script>

<template>
  <div class="space-y-4">
    <!-- Summary strip -->
    <div v-if="summary" class="grid grid-cols-5 gap-3">
      <div class="rounded-lg border border-[#e5e7eb] bg-white p-3">
        <div class="text-[11px] text-[#71717a]">账号总数</div>
        <div class="text-lg font-semibold text-[#18181b] tabular-nums">{{ summary.ok_count + summary.error_count }}</div>
        <div class="text-[10px] text-[#a1a1aa] mt-0.5">{{ summary.ok_count }} 可用 / {{ summary.error_count }} 异常</div>
      </div>
      <div class="rounded-lg border border-[#e5e7eb] bg-white p-3">
        <div class="text-[11px] text-[#71717a]">总额度</div>
        <div class="text-lg font-semibold text-[#18181b] tabular-nums">{{ summary.total_limit.toLocaleString() }}</div>
        <div class="text-[10px] text-[#a1a1aa] mt-0.5">invocations / 月</div>
      </div>
      <div class="rounded-lg border border-[#e5e7eb] bg-white p-3">
        <div class="text-[11px] text-[#71717a]">本月已用</div>
        <div class="text-lg font-semibold text-[#18181b] tabular-nums">
          {{ summary.total_used.toLocaleString(undefined, { maximumFractionDigits: 2 }) }}
        </div>
        <div class="text-[10px] mt-0.5" :style="{ color: percentColor(summary.percent) }">
          {{ summary.percent }}% 已消耗
        </div>
      </div>
      <div class="rounded-lg border border-[#e5e7eb] bg-white p-3">
        <div class="text-[11px] text-[#71717a]">剩余</div>
        <div class="text-lg font-semibold text-[#16a34a] tabular-nums">
          {{ summary.total_remaining.toLocaleString(undefined, { maximumFractionDigits: 2 }) }}
        </div>
        <div class="text-[10px] text-[#a1a1aa] mt-0.5">可用 invocations</div>
      </div>
      <div class="rounded-lg border border-[#e5e7eb] bg-white p-3">
        <div class="text-[11px] text-[#71717a]">状态</div>
        <div class="text-lg font-semibold tabular-nums flex items-center gap-1.5">
          <span class="text-[#16a34a]">{{ healthyCount }}</span>
          <span class="text-[#d4d4d8] text-sm">/</span>
          <span class="text-[#d97706]">{{ warningCount }}</span>
          <span class="text-[#d4d4d8] text-sm">/</span>
          <span class="text-[#dc2626]">{{ criticalCount }}</span>
        </div>
        <div class="text-[10px] text-[#a1a1aa] mt-0.5">
          正常 / 高水位 / 耗尽
          <span v-if="disabledCount > 0" class="ml-1 text-[#a1a1aa]">· {{ disabledCount }} 禁用</span>
        </div>
      </div>
    </div>

    <!-- Toolbar + trend -->
    <div class="rounded-xl border border-[#e5e7eb] bg-white">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-[#e5e7eb]">
        <div class="text-sm font-medium text-[#18181b]">用量趋势</div>
        <div class="flex-1" />
        <select
          v-model="historyHours"
          class="px-2.5 py-1.5 text-xs rounded-md border border-[#e5e7eb] bg-white focus:outline-none focus:border-[#18181b]"
          @change="loadHistory"
        >
          <option :value="6">近 6 小时</option>
          <option :value="24">近 24 小时</option>
          <option :value="168">近 7 天</option>
          <option :value="720">近 30 天</option>
        </select>
        <select
          v-model="selectedAccountId"
          class="px-2.5 py-1.5 text-xs rounded-md border border-[#e5e7eb] bg-white focus:outline-none focus:border-[#18181b]"
          @change="loadHistory"
        >
          <option value="all">全部账号</option>
          <option v-for="a in accounts" :key="a.id" :value="a.id">{{ a.id }}</option>
        </select>
        <button
          class="inline-flex items-center gap-1.5 px-2.5 py-1.5 text-xs rounded-md border border-[#e5e7eb] text-[#71717a] hover:text-[#18181b] hover:bg-[#fafafa]"
          @click="loadUsage(); loadHistory()"
        >
          <Icon name="refresh-cw" :size="12" />
          刷新
        </button>
        <button
          :disabled="refreshing"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs rounded-md bg-[#18181b] text-white hover:bg-[#27272a] disabled:opacity-50"
          @click="forceRefresh"
        >
          <Icon name="refresh-cw" :size="12" :class="refreshing ? 'animate-spin' : ''" />
          {{ refreshing ? '查询中...' : '强制同步' }}
        </button>
      </div>

      <div class="px-2 py-3">
        <div v-if="!chartTsRange" class="text-center text-xs text-[#a1a1aa] py-12">
          暂无历史数据（每 5 分钟自动采样，首次采样约需等待）
        </div>
        <svg v-else :viewBox="`0 0 ${chartBox.w} ${chartBox.h}`" class="w-full h-[200px]">
          <g>
            <line v-for="p in [0, 25, 50, 75, 100]" :key="p"
              :x1="chartBox.padLeft" :x2="chartBox.w - chartBox.padRight"
              :y1="chartBox.padTop + (1 - p / 100) * (chartBox.h - chartBox.padTop - chartBox.padBottom)"
              :y2="chartBox.padTop + (1 - p / 100) * (chartBox.h - chartBox.padTop - chartBox.padBottom)"
              stroke="#f4f4f5" stroke-width="1" />
            <text v-for="p in [0, 25, 50, 75, 100]" :key="`l${p}`"
              :x="chartBox.padLeft - 6"
              :y="chartBox.padTop + (1 - p / 100) * (chartBox.h - chartBox.padTop - chartBox.padBottom) + 3"
              text-anchor="end" font-size="9" fill="#a1a1aa">{{ p }}%</text>
          </g>
          <line
            :x1="chartBox.padLeft" :x2="chartBox.w - chartBox.padRight"
            :y1="chartBox.padTop + 0.1 * (chartBox.h - chartBox.padTop - chartBox.padBottom)"
            :y2="chartBox.padTop + 0.1 * (chartBox.h - chartBox.padTop - chartBox.padBottom)"
            stroke="#d97706" stroke-width="1" stroke-dasharray="2,3" opacity="0.6" />
          <line
            :x1="chartBox.padLeft" :x2="chartBox.w - chartBox.padRight"
            :y1="chartBox.padTop + 0.02 * (chartBox.h - chartBox.padTop - chartBox.padBottom)"
            :y2="chartBox.padTop + 0.02 * (chartBox.h - chartBox.padTop - chartBox.padBottom)"
            stroke="#dc2626" stroke-width="1" stroke-dasharray="2,3" opacity="0.6" />
          <g>
            <text v-for="(t, i) in xTicks" :key="i"
              :x="t.x" :y="chartBox.h - 6"
              text-anchor="middle" font-size="9" fill="#a1a1aa">{{ t.label }}</text>
          </g>
          <g v-for="s in chartSeries" :key="s.accountId">
            <path
              :d="seriesPath(s, chartTsRange!.min, chartTsRange!.max)"
              fill="none" :stroke="s.color"
              stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round" />
            <circle v-for="(p, i) in s.points" :key="i"
              :cx="chartXY(p, chartTsRange!.min, chartTsRange!.max).x"
              :cy="chartXY(p, chartTsRange!.min, chartTsRange!.max).y"
              :r="s.points.length < 30 ? 2 : 1.2" :fill="s.color" />
          </g>
        </svg>

        <div v-if="chartSeries.length > 0" class="flex flex-wrap gap-3 px-2 text-[11px] text-[#71717a]">
          <div v-for="s in chartSeries" :key="s.accountId" class="flex items-center gap-1.5">
            <span :style="{ background: s.color }" class="inline-block w-2.5 h-2.5 rounded-full" />
            <span class="font-mono">{{ s.accountId }}</span>
          </div>
          <div class="flex items-center gap-1.5 ml-auto text-[#a1a1aa]">
            <span class="inline-block w-4 border-t border-dashed border-[#d97706]" />
            <span>90% 降权</span>
            <span class="inline-block w-4 border-t border-dashed border-[#dc2626] ml-2" />
            <span>98% 跳过</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Account cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div v-for="acct in accounts" :key="acct.id"
        class="rounded-xl border border-[#e5e7eb] bg-white p-4 space-y-3"
        :class="acct.disabled ? 'opacity-60' : ''">
        <div class="flex items-start gap-2">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-mono text-sm font-semibold text-[#18181b]">{{ acct.id }}</span>
              <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-medium border"
                :class="subBadgeClass(acct.subscription?.title)">
                {{ acct.subscription?.title || '未知订阅' }}
              </span>
              <span v-if="acct.disabled" class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-[#f4f4f5] text-[#71717a] border border-[#e5e7eb]">已禁用</span>
              <span v-if="acct.error" class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-[#fef2f2] text-[#dc2626] border border-[#fecaca]">{{ acct.error.slice(0, 40) }}</span>
              <span v-else-if="acct.percent !== undefined && acct.percent >= 98"
                class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-[#fef2f2] text-[#dc2626] border border-[#fecaca]">耗尽</span>
              <span v-else-if="acct.percent !== undefined && acct.percent >= 90"
                class="inline-flex px-1.5 py-0.5 rounded text-[10px] bg-[#fffbeb] text-[#d97706] border border-[#fde68a]">高水位</span>
            </div>
            <div class="text-[11px] text-[#a1a1aa] mt-0.5 truncate">
              {{ acct.source }} · {{ acct.auth_type || '—' }}
            </div>
          </div>
          <div class="flex items-center gap-1">
            <button
              class="p-1.5 rounded hover:bg-[#f4f4f5] text-[#71717a] hover:text-[#18181b]"
              title="测试 token" @click="handleTestAccount(acct)">
              <Icon name="zap" :size="12" />
            </button>
            <button
              class="p-1.5 rounded hover:bg-[#f4f4f5] text-[#71717a] hover:text-[#18181b]"
              :title="acct.disabled ? '启用' : '禁用'" @click="handleToggleDisable(acct)">
              <Icon :name="acct.disabled ? 'play' : 'pause'" :size="12" />
            </button>
          </div>
        </div>

        <!-- Quota bar -->
        <div v-if="!acct.error">
          <div class="flex items-baseline justify-between mb-1">
            <div class="text-[11px] text-[#71717a]">月度额度</div>
            <div class="text-[11px] tabular-nums">
              <span class="font-semibold" :style="{ color: percentColor(acct.percent || 0) }">
                {{ Number(acct.used || 0).toLocaleString(undefined, { maximumFractionDigits: 2 }) }}
              </span>
              <span class="text-[#a1a1aa]"> / {{ Number(acct.limit || 0).toLocaleString() }}</span>
              <span class="ml-1.5 font-semibold" :style="{ color: percentColor(acct.percent || 0) }">
                {{ (acct.percent || 0).toFixed(1) }}%
              </span>
            </div>
          </div>
          <div class="h-2 rounded-full bg-[#f4f4f5] overflow-hidden">
            <div class="h-full rounded-full transition-all"
              :style="{ width: Math.min(100, acct.percent || 0) + '%', background: percentColor(acct.percent || 0) }" />
          </div>
        </div>

        <!-- Overage info -->
        <div v-if="!acct.error && acct.overage && acct.overage.status === 'ENABLED'"
          class="flex items-center justify-between text-[11px] p-2 rounded-md bg-[#fffbeb] border border-[#fde68a]">
          <span class="text-[#92400e]">超量计费已启用</span>
          <span class="font-mono text-[#92400e]">
            {{ acct.overage.used }} / {{ acct.overage.cap }} ·
            ${{ (acct.overage.charges || 0).toFixed(2) }}
          </span>
        </div>

        <!-- Free trial -->
        <div v-if="!acct.error && acct.free_trial" class="flex items-center justify-between text-[11px] p-2 rounded-md bg-[#eff6ff] border border-[#bfdbfe]">
          <span class="text-[#1d4ed8]">免费试用</span>
          <span class="font-mono text-[#1d4ed8]">
            {{ acct.free_trial.used }} / {{ acct.free_trial.limit }} ·
            {{ acct.free_trial.expiry ? new Date(acct.free_trial.expiry * 1000).toLocaleDateString('zh-CN') + ' 到期' : '' }}
          </span>
        </div>

        <!-- Meta row -->
        <div class="grid grid-cols-3 gap-3 text-[11px] pt-2 border-t border-[#f4f4f5]">
          <div>
            <div class="text-[#a1a1aa]">本月重置</div>
            <div class="text-[#18181b] mt-0.5 font-mono">{{ resetCountdown(acct.next_date_reset) }}</div>
          </div>
          <div>
            <div class="text-[#a1a1aa]">活跃会话</div>
            <div class="text-[#18181b] mt-0.5 font-mono">{{ acct.active_sessions ?? 0 }}</div>
          </div>
          <div>
            <div class="text-[#a1a1aa]">总请求</div>
            <div class="text-[#18181b] mt-0.5 font-mono">{{ acct.total_requests ?? 0 }}</div>
          </div>
        </div>
      </div>
    </div>

    <div v-if="loading && !usage" class="rounded-xl border border-[#e5e7eb] bg-white p-12 text-center text-xs text-[#a1a1aa]">
      加载中…
    </div>
    <div v-else-if="!loading && accounts.length === 0" class="rounded-xl border border-[#e5e7eb] bg-white p-12 text-center text-xs text-[#a1a1aa]">
      暂无 Kiro 账号
    </div>
  </div>
</template>
