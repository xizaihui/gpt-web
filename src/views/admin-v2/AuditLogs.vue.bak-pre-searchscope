<script setup lang="ts">
import { ref, computed, onMounted, onUnmounted, watch } from 'vue'
import Icon from '@/components/common/Icon.vue'

type Source = 'clewdr' | 'oai'

const source = ref<Source>('clewdr')
const logs = ref<any[]>([])
const total = ref(0)
const page = ref(1)
const pageSize = ref(30)
const loading = ref(false)
const stats = ref<any>(null)
const distincts = ref<any>({})

const filter = ref({
  date_from: '', date_to: '', model: '', session_id: '', api_key_hash: '',
  client_type: '', cookie_short: '', status: '', has_tools: '', is_stream: '',
  min_prompt_tokens: '', min_completion_tokens: '', search: '',
})

const autoRefresh = ref(false)
let refreshTimer: ReturnType<typeof setInterval> | null = null

const showDetail = ref(false)
const detail = ref<any>(null)
const detailTab = ref<'overview' | 'request' | 'response' | 'raw'>('overview')
const apiPrefix = '/api/audit'

function authHeader() {
  const t = localStorage.getItem('SECRET_TOKEN') || ''
  return t ? { Authorization: `Bearer ${t}` } : {}
}

async function fetchJson(url: string, opts: any = {}) {
  const r = await fetch(url, { ...opts, headers: { 'Content-Type': 'application/json', ...authHeader(), ...(opts.headers || {}) } })
  if (!r.ok) throw new Error(`HTTP ${r.status}`)
  return r.json()
}

async function load() {
  loading.value = true
  try {
    const params = new URLSearchParams()
    params.set('page', String(page.value))
    params.set('pageSize', String(pageSize.value))
    for (const [k, v] of Object.entries(filter.value)) { if (v) params.set(k, String(v)) }
    const res = await fetchJson(`${apiPrefix}/${source.value}/logs?${params}`)
    if (res.status === 'Success') { logs.value = res.data.data || []; total.value = res.data.total || 0 }
  } catch (e) { console.error(e) }
  loading.value = false
}

async function loadStats() { try { const res = await fetchJson(`${apiPrefix}/stats`); if (res.status === 'Success') stats.value = res.data } catch (e) { console.error(e) } }
async function loadDistincts() { try { const res = await fetchJson(`${apiPrefix}/distincts`); if (res.status === 'Success') distincts.value = res.data } catch (e) { console.error(e) } }

async function openDetail(row: any) {
  showDetail.value = true; detailTab.value = 'overview'; detail.value = null
  try { const res = await fetchJson(`${apiPrefix}/${source.value}/logs/${row.id}`); if (res.status === 'Success') detail.value = res.data } catch (e) { console.error(e) }
}
function closeDetail() { showDetail.value = false; detail.value = null }

function applyFilters() { page.value = 1; load(); loadStats() }
function resetFilters() {
  filter.value = { date_from: '', date_to: '', model: '', session_id: '', api_key_hash: '', client_type: '', cookie_short: '', status: '', has_tools: '', is_stream: '', min_prompt_tokens: '', min_completion_tokens: '', search: '' }
  applyFilters()
}
function switchSource(s: Source) { source.value = s; page.value = 1; resetFilters() }

function setDateShortcut(key: '1h' | '6h' | '24h' | '7d' | '') {
  if (!key) { filter.value.date_from = ''; filter.value.date_to = ''; applyFilters(); return }
  const now = new Date(); const ms: Record<string, number> = { '1h': 3600e3, '6h': 6 * 3600e3, '24h': 24 * 3600e3, '7d': 7 * 24 * 3600e3 }
  const from = new Date(now.getTime() - ms[key])
  filter.value.date_from = from.toISOString().slice(0, 16)
  filter.value.date_to = now.toISOString().slice(0, 16)
  applyFilters()
}

function goPage(p: number) { if (p < 1) return; page.value = p; load() }
const totalPages = computed(() => Math.max(1, Math.ceil(total.value / pageSize.value)))

// All user messages from the request body — shows raw user input for forensics
const allUserMessages = computed<string[]>(() => {
  const d: any = detail.value
  if (!d) return []
  let body: any = d.request_body
  if (typeof body === 'string') { try { body = JSON.parse(body) } catch { return [] } }
  if (!body) return []
  const msgs: any[] = Array.isArray(body.messages) ? body.messages : []
  const out: string[] = []
  for (const m of msgs) {
    if (m?.role !== 'user') continue
    const c = m.content
    if (typeof c === 'string') { out.push(c); continue }
    if (Array.isArray(c)) {
      const parts: string[] = []
      for (const b of c) {
        if (!b || typeof b !== 'object') continue
        if (b.type === 'text' && typeof b.text === 'string') parts.push(b.text)
        else if (b.type === 'tool_result') {
          const tc = b.content
          if (typeof tc === 'string') parts.push(`[tool_result]\n${tc}`)
          else if (Array.isArray(tc)) {
            const tparts = tc.filter((x: any) => x?.type === 'text' && typeof x.text === 'string').map((x: any) => x.text)
            parts.push(`[tool_result]\n${tparts.join('\n')}`)
          } else parts.push('[tool_result]')
        }
        else if (b.type === 'image') parts.push('[image]')
        else if (b.type === 'document') parts.push('[document]')
      }
      if (parts.length) out.push(parts.join('\n'))
    }
  }
  return out
})

function fmtTime(iso: string) { if (!iso) return ''; return new Date(iso).toLocaleString('zh-CN', { hour12: false }) }
function fmtRelative(iso: string) {
  if (!iso) return ''
  const diff = Date.now() - new Date(iso).getTime()
  if (diff < 60e3) return `${Math.floor(diff / 1000)}秒前`
  if (diff < 3600e3) return `${Math.floor(diff / 60e3)}分钟前`
  if (diff < 86400e3) return `${Math.floor(diff / 3600e3)}小时前`
  return `${Math.floor(diff / 86400e3)}天前`
}
function fmtDuration(ms: number | null | undefined) { if (!ms && ms !== 0) return '-'; return ms < 1000 ? `${ms}ms` : `${(ms / 1000).toFixed(1)}s` }
function fmtNum(n: number | string | null | undefined) {
  if (n === null || n === undefined) return '-'
  const v = typeof n === 'string' ? parseInt(n, 10) : n
  if (v >= 1000000) return `${(v / 1000000).toFixed(2)}M`
  if (v >= 1000) return `${(v / 1000).toFixed(1)}K`
  return String(v)
}

function clientTypeBadge(ct: string | null | undefined) {
  if (!ct) return { label: '-', color: '#a1a1aa' }
  const map: Record<string, { label: string; color: string }> = {
    'claude-code': { label: 'Claude Code', color: '#f59e0b' },
    'codex': { label: 'Codex', color: '#10b981' },
    'chatgpt-web': { label: 'ChatGPT Web', color: '#6366f1' },
    'cherry-studio': { label: 'Cherry Studio', color: '#ef4444' },
    'chatbox': { label: 'Chatbox', color: '#3b82f6' },
    'anthropic-sdk': { label: 'Anthropic SDK', color: '#ec4899' },
    'python-script': { label: 'Python', color: '#8b5cf6' },
    'node-script': { label: 'Node', color: '#84cc16' },
    'curl': { label: 'curl', color: '#6b7280' },
    'unknown': { label: '未知', color: '#a1a1aa' },
  }
  return map[ct] || { label: ct, color: '#71717a' }
}

function copy(text: string) { navigator.clipboard.writeText(text).catch(() => {}) }
function prettyJson(raw: any) { if (raw === null || raw === undefined) return ''; try { return JSON.stringify(typeof raw === 'string' ? JSON.parse(raw) : raw, null, 2) } catch { return typeof raw === 'string' ? raw : JSON.stringify(raw) } }

watch(autoRefresh, (v) => {
  if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null }
  if (v) refreshTimer = setInterval(() => { if (page.value === 1) load() }, 10000)
})

onMounted(() => { load(); loadStats(); loadDistincts() })
onUnmounted(() => { if (refreshTimer) clearInterval(refreshTimer) })
</script>

<template>
  <div class="p-6 space-y-4">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-xl font-semibold text-[#18181b]">审计日志</h2>
        <p class="text-sm text-[#71717a] mt-0.5">完整请求/响应审计 · 默认保留 7 天 · TLS 直连 postgres</p>
      </div>
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-2 text-xs text-[#71717a]">
          <input v-model="autoRefresh" type="checkbox" class="rounded"> 自动刷新(10s)
        </label>
        <button class="px-3 py-1.5 text-xs border border-[#e5e7eb] rounded-md hover:bg-[#f4f4f5] flex items-center gap-1.5" @click="load()">
          <Icon name="refresh-cw" :size="12" /> 刷新
        </button>
      </div>
    </div>

    <div class="flex gap-2 border-b border-[#e5e7eb]">
      <button class="px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors" :class="source === 'clewdr' ? 'border-[#18181b] text-[#18181b]' : 'border-transparent text-[#71717a] hover:text-[#18181b]'" @click="switchSource('clewdr')">
        ClewdR 日志 <span v-if="stats?.overview?.[0]?.total" class="ml-1 text-[#a1a1aa]">({{ stats.overview[0].total }}/24h)</span>
      </button>
      <button class="px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors" :class="source === 'oai' ? 'border-[#18181b] text-[#18181b]' : 'border-transparent text-[#71717a] hover:text-[#18181b]'" @click="switchSource('oai')">
        OpenAI Gateway <span v-if="stats?.overview?.[1]?.total" class="ml-1 text-[#a1a1aa]">({{ stats.overview[1].total }}/24h)</span>
      </button>
    </div>

    <div v-if="stats" class="grid grid-cols-4 gap-3">
      <template v-for="(row, i) in stats.overview" :key="i">
        <template v-if="(source === 'clewdr' && row.source === 'clewdr') || (source === 'oai' && row.source === 'oai')">
          <div class="rounded-lg border border-[#e5e7eb] bg-white p-3">
            <div class="text-xs text-[#71717a]">总请求数(24h)</div>
            <div class="text-xl font-semibold mt-1">{{ fmtNum(row.total) }}</div>
            <div v-if="Number(row.errors) > 0" class="text-xs text-[#dc2626] mt-0.5">{{ row.errors }} 失败</div>
          </div>
