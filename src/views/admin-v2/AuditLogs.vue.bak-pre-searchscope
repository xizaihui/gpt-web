    </div>

    <!-- Detail drawer -->
    <div v-if="showDetail" class="fixed inset-0 z-50 flex justify-end" @click.self="closeDetail">      <div class="absolute inset-0 bg-black/30"></div>
      <div class="relative w-[960px] max-w-full h-full bg-white shadow-2xl flex flex-col">
        <div class="flex items-center justify-between px-5 py-3 border-b border-[#e5e7eb]">
          <div>
            <div class="text-base font-semibold text-[#18181b]">日志详情</div>
            <div v-if="detail" class="text-xs text-[#71717a] mt-0.5">
