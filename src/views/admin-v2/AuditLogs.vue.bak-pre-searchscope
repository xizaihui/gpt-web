            <div class="text-xs text-[#71717a]">输出 Tokens</div>
            <div class="text-xl font-semibold mt-1">{{ fmtNum(row.sum_completion) }}</div>
            <div class="text-xs text-[#71717a] mt-0.5">缓存写 {{ fmtNum(row.sum_cache_write) }}</div>
          </div>
          <div class="rounded-lg border border-[#e5e7eb] bg-white p-3">
            <div class="text-xs text-[#71717a]">活跃用户</div>
            <div class="text-xl font-semibold mt-1">{{ row.unique_users }}</div>
            <div class="text-xs text-[#71717a] mt-0.5">按 api_key_hash 去重</div>
          </div>
        </template>
      </template>
    </div>

    <div class="rounded-lg border border-[#e5e7eb] bg-white p-3 space-y-2">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs text-[#71717a] mr-1">时间:</span>
        <button v-for="k in (['1h', '6h', '24h', '7d', ''] as const)" :key="k" class="px-2 py-0.5 text-xs border border-[#e5e7eb] rounded hover:bg-[#f4f4f5]" @click="setDateShortcut(k)">{{ k || '全部' }}</button>
        <input v-model="filter.date_from" type="datetime-local" class="text-xs border border-[#e5e7eb] rounded px-2 py-0.5">
        <span class="text-xs text-[#71717a]">→</span>
