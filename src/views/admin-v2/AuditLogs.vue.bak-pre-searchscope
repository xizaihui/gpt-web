      </div>

      <div class="grid grid-cols-6 gap-2">
        <input v-model="filter.search" placeholder="全文搜索（含敏感词检测）" class="col-span-2 text-sm border border-[#e5e7eb] rounded-md px-3 py-1.5 focus:outline-none focus:border-[#18181b]" @keyup.enter="applyFilters" />
        <select v-model="filter.model" class="text-sm border border-[#e5e7eb] rounded-md px-2 py-1.5" @change="applyFilters">
          <option value="">全部模型</option>
          <option v-for="m in (source === 'clewdr' ? distincts.clewdr_models : distincts.oai_models) || []" :key="m" :value="m">{{ m }}</option>
        </select>
        <select v-model="filter.client_type" class="text-sm border border-[#e5e7eb] rounded-md px-2 py-1.5" @change="applyFilters">
          <option value="">全部客户端</option>
          <option v-for="c in (source === 'clewdr' ? distincts.clewdr_client_types : distincts.oai_client_types) || []" :key="c" :value="c">{{ clientTypeBadge(c).label }}</option>
        </select>
        <select v-model="filter.status" class="text-sm border border-[#e5e7eb] rounded-md px-2 py-1.5" @change="applyFilters">
          <option value="">全部状态</option>
          <option value="success">✅ 成功</option>
          <option value="error">❌ 失败</option>
        </select>
        <select v-model="filter.is_stream" class="text-sm border border-[#e5e7eb] rounded-md px-2 py-1.5" @change="applyFilters">
          <option value="">流/非流</option>
          <option value="true">📡 流式</option>
          <option value="false">📄 非流</option>
        </select>
      </div>

      <div class="grid grid-cols-6 gap-2">
        <input v-model="filter.api_key_hash" placeholder="API Key hash (16位)" class="text-sm border border-[#e5e7eb] rounded-md px-3 py-1.5" @keyup.enter="applyFilters">
        <input v-model="filter.session_id" placeholder="Session ID" class="text-sm border border-[#e5e7eb] rounded-md px-3 py-1.5" @keyup.enter="applyFilters">
        <select v-if="source === 'clewdr'" v-model="filter.cookie_short" class="text-sm border border-[#e5e7eb] rounded-md px-2 py-1.5" @change="applyFilters">
          <option value="">全部号</option>
          <option v-for="c in distincts.clewdr_cookies || []" :key="c" :value="c">{{ c }}</option>
        </select>
        <div v-else></div>
        <select v-model="filter.has_tools" class="text-sm border border-[#e5e7eb] rounded-md px-2 py-1.5" @change="applyFilters">
          <option value="">工具任意</option>
          <option value="true">🛠️ 含工具</option>
        </select>
        <input v-model="filter.min_prompt_tokens" placeholder="最小 prompt tokens" type="number" class="text-sm border border-[#e5e7eb] rounded-md px-3 py-1.5" @keyup.enter="applyFilters">
        <div class="flex gap-2">
          <button class="flex-1 px-3 py-1.5 text-xs bg-[#18181b] text-white rounded-md hover:bg-[#27272a]" @click="applyFilters">搜索</button>
          <button class="px-2 py-1.5 text-xs border border-[#e5e7eb] rounded-md hover:bg-[#f4f4f5]" @click="resetFilters">重置</button>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-[#e5e7eb] bg-white overflow-hidden">
      <div v-if="loading" class="p-10 text-center text-sm text-[#71717a]">加载中...</div>
      <div v-else-if="logs.length === 0" class="p-10 text-center text-sm text-[#a1a1aa]">暂无数据</div>
      <table v-else class="w-full text-xs">
        <thead class="bg-[#fafafa] text-[#71717a]">
          <tr>
            <th class="px-3 py-2 text-left font-medium">时间</th>
            <th class="px-3 py-2 text-left font-medium">客户端</th>
            <th class="px-3 py-2 text-left font-medium">模型</th>
            <th class="px-3 py-2 text-left font-medium">用户</th>
            <th class="px-3 py-2 text-left font-medium w-64">最后一条 user</th>
            <th class="px-3 py-2 text-left font-medium w-64">响应预览</th>
            <th class="px-3 py-2 text-right font-medium">Tokens</th>
            <th class="px-3 py-2 text-right font-medium">缓存</th>
            <th class="px-3 py-2 text-right font-medium">耗时</th>
            <th class="px-3 py-2 text-center font-medium">状态</th>
            <th class="px-3 py-2 text-right font-medium">操作</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="row in logs" :key="row.id" class="border-t border-[#e5e7eb] hover:bg-[#fafafa]">
            <td class="px-3 py-2 whitespace-nowrap" :title="fmtTime(row.created_at)">
              <div class="text-[#18181b]">{{ fmtRelative(row.created_at) }}</div>
              <div class="text-[10px] text-[#a1a1aa]">{{ fmtTime(row.created_at).split(' ')[1] }}</div>
            </td>
            <td class="px-3 py-2">
              <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium" :style="{ background: clientTypeBadge(row.client_type).color + '22', color: clientTypeBadge(row.client_type).color }">
                {{ clientTypeBadge(row.client_type).label }}
              </span>
              <span v-if="row.is_stream" class="ml-1 text-[10px] text-[#71717a]">📡</span>
              <span v-if="row.has_tools" class="ml-1 text-[10px] text-[#71717a]">🛠️</span>
            </td>
            <td class="px-3 py-2 text-[#18181b]">{{ row.model }}</td>
            <td class="px-3 py-2 font-mono text-[10px] text-[#71717a] cursor-pointer" :title="(row.api_key_hash || '') + ' 点击复制'" @click="copy(row.api_key_hash || '')">{{ (row.api_key_hash || '').slice(0, 8) }}…</td>
            <td class="px-3 py-2 text-[#18181b] truncate max-w-xs" :title="row.first_user_message || ''">{{ row.first_user_message || '-' }}</td>
            <td class="px-3 py-2 text-[#52525b] truncate max-w-xs" :title="row.response_preview || ''">{{ row.response_preview || '-' }}</td>
            <td class="px-3 py-2 text-right whitespace-nowrap">
              <span class="text-[#18181b]">{{ fmtNum(row.prompt_tokens) }}</span>
              <span class="text-[#a1a1aa]"> / </span>
              <span class="text-[#16a34a]">{{ fmtNum(row.completion_tokens) }}</span>
