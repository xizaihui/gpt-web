            </td>
            <td class="px-3 py-2 text-right text-[#71717a]">{{ fmtDuration(row.duration_ms) }}</td>
            <td class="px-3 py-2 text-center">
              <span v-if="row.status_code < 400" class="text-[#16a34a]">✓</span>
              <span v-else class="text-[#dc2626]" :title="row.error_msg || ''">✗</span>
