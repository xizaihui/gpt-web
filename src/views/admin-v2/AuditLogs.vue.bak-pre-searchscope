        </div>

        <div v-if="!detail" class="flex-1 flex items-center justify-center text-sm text-[#71717a]">加载中...</div>

        <template v-else>
          <div class="flex gap-1 px-5 pt-2 border-b border-[#e5e7eb]">
            <button v-for="t in (['overview', 'request', 'response', 'raw'] as const)" :key="t"
              class="px-3 py-1.5 text-xs font-medium border-b-2 -mb-px transition-colors"
              :class="detailTab === t ? 'border-[#18181b] text-[#18181b]' : 'border-transparent text-[#71717a] hover:text-[#18181b]'"
              @click="detailTab = t">
              {{ t === 'overview' ? '概览' : t === 'request' ? '请求体' : t === 'response' ? '响应' : '原始 JSON' }}
            </button>
          </div>

          <div class="flex-1 overflow-auto p-5 space-y-4 text-sm">
            <template v-if="detailTab === 'overview'">
              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-2">
                  <div class="text-xs font-medium text-[#71717a] uppercase">客户端</div>
                  <div class="space-y-1 text-xs">
                    <div><span class="text-[#71717a] w-24 inline-block">类型:</span>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded font-medium"
                        :style="{ background: clientTypeBadge(detail.client_type).color + '22', color: clientTypeBadge(detail.client_type).color }">
                        {{ clientTypeBadge(detail.client_type).label }}
                      </span>
                    </div>
                    <div><span class="text-[#71717a] w-24 inline-block">User-Agent:</span> <span class="break-all">{{ detail.user_agent || '-' }}</span></div>
                    <div><span class="text-[#71717a] w-24 inline-block">IP:</span> {{ detail.client_ip || '-' }}</div>
                    <div><span class="text-[#71717a] w-24 inline-block">API Key:</span> <code class="font-mono cursor-pointer" @click="copy(detail.api_key_hash || '')">{{ detail.api_key_hash || '-' }}</code></div>
                    <div><span class="text-[#71717a] w-24 inline-block">Session:</span> <code class="font-mono cursor-pointer" @click="copy(detail.session_id || '')">{{ detail.session_id || '-' }}</code></div>
                    <div v-if="detail.cookie_short"><span class="text-[#71717a] w-24 inline-block">Cookie:</span> {{ detail.cookie_short }}</div>
                  </div>
                </div>
                <div class="space-y-2">
                  <div class="text-xs font-medium text-[#71717a] uppercase">请求</div>
                  <div class="space-y-1 text-xs">
                    <div><span class="text-[#71717a] w-24 inline-block">Endpoint:</span> <code class="font-mono">{{ detail.endpoint }}</code></div>
                    <div><span class="text-[#71717a] w-24 inline-block">模型:</span> <b>{{ detail.model }}</b></div>
                    <div><span class="text-[#71717a] w-24 inline-block">流式:</span> {{ detail.is_stream ? '📡 是' : '📄 否' }}</div>
                    <div><span class="text-[#71717a] w-24 inline-block">工具:</span> {{ detail.has_tools ? `🛠️ ${detail.tool_count}个` : '无' }}</div>
                    <div><span class="text-[#71717a] w-24 inline-block">耗时:</span> {{ fmtDuration(detail.duration_ms) }}</div>
                    <div><span class="text-[#71717a] w-24 inline-block">状态码:</span>
                      <span :class="detail.status_code < 400 ? 'text-[#16a34a]' : 'text-[#dc2626]'">{{ detail.status_code }}</span>
                      <span v-if="detail.stop_reason || detail.finish_reason_norm" class="ml-2 text-[#71717a]">({{ detail.stop_reason || detail.finish_reason_norm }})</span>
                    </div>
                    <div v-if="detail.error_msg" class="text-[#dc2626] break-all">错误: {{ detail.error_msg }}</div>
                  </div>
                </div>
              </div>

              <div>
                <div class="text-xs font-medium text-[#71717a] uppercase mb-2">Token 用量</div>
                <div class="grid grid-cols-5 gap-2 text-xs">
                  <div class="rounded border border-[#e5e7eb] p-2">
                    <div class="text-[#71717a]">输入</div>
                    <div class="text-base font-semibold text-[#18181b] mt-0.5">{{ fmtNum(detail.prompt_tokens) }}</div>
                  </div>
                  <div class="rounded border border-[#e5e7eb] p-2">
                    <div class="text-[#71717a]">输出</div>
                    <div class="text-base font-semibold text-[#16a34a] mt-0.5">{{ fmtNum(detail.completion_tokens) }}</div>
                  </div>
                  <div class="rounded border border-[#e5e7eb] p-2">
                    <div class="text-[#71717a]">🔄 缓存读</div>
                    <div class="text-base font-semibold text-[#2563eb] mt-0.5">{{ fmtNum(detail.cache_read_tokens || detail.cached_tokens) }}</div>
                  </div>
                  <div class="rounded border border-[#e5e7eb] p-2">
                    <div class="text-[#71717a]">💾 缓存写</div>
                    <div class="text-base font-semibold text-[#7c3aed] mt-0.5">{{ fmtNum(detail.cache_write_tokens) }}</div>
                  </div>
                  <div class="rounded border border-[#e5e7eb] p-2">
                    <div class="text-[#71717a]">req/resp 大小</div>
                    <div class="text-xs font-medium text-[#18181b] mt-0.5">
                      {{ Math.round((detail.request_size_bytes || 0) / 1024) }}KB
                      <span class="text-[#a1a1aa]">/</span>
                      {{ Math.round((detail.response_size_bytes || 0) / 1024) }}KB
                    </div>
                    <div v-if="detail.request_truncated || detail.response_truncated" class="text-[10px] text-[#f59e0b]">⚠️ 已截断</div>
                  </div>
                </div>
              </div>

              <div v-if="allUserMessages.length">
                <div class="text-xs font-medium text-[#71717a] uppercase mb-2">用户输入 ({{ allUserMessages.length }} 条，本轮最后一条触发回复)</div>
                <div class="space-y-2">
                  <div
                    v-for="(um, i) in allUserMessages"
                    :key="i"
                    class="border rounded"
                    :class="i === allUserMessages.length - 1 ? 'border-[#f59e0b] bg-[#fffbeb]' : 'border-[#e5e7eb] bg-[#fafafa]'"
                  >
                    <div class="px-3 py-1 text-[10px] text-[#71717a] border-b" :class="i === allUserMessages.length - 1 ? 'border-[#f59e0b] bg-[#fef3c7]' : 'border-[#e5e7eb]'">
                      user #{{ i + 1 }}<span v-if="i === allUserMessages.length - 1" class="ml-2 text-[#b45309]">← 触发本轮回复</span>
                    </div>
                    <pre class="text-xs p-3 max-h-48 overflow-auto whitespace-pre-wrap text-[#18181b]">{{ um }}</pre>
                  </div>
                </div>
              </div>
              <div v-else-if="detail.first_user_message">
                <div class="text-xs font-medium text-[#71717a] uppercase mb-2">最后一条用户消息</div>
                <pre class="text-xs bg-[#fafafa] border border-[#e5e7eb] rounded p-3 max-h-48 overflow-auto whitespace-pre-wrap">{{ detail.first_user_message }}</pre>
              </div>
              <div v-if="detail.system_prompt_head">
                <div class="text-xs font-medium text-[#71717a] uppercase mb-2">System Prompt (前 200 字)</div>
                <pre class="text-xs bg-[#fafafa] border border-[#e5e7eb] rounded p-3 max-h-32 overflow-auto whitespace-pre-wrap">{{ detail.system_prompt_head }}</pre>
              </div>
              <div v-if="detail.response_text">
                <div class="text-xs font-medium text-[#71717a] uppercase mb-2">响应文本</div>
                <pre class="text-xs bg-[#fafafa] border border-[#e5e7eb] rounded p-3 max-h-96 overflow-auto whitespace-pre-wrap">{{ detail.response_text }}</pre>
              </div>
            </template>

            <template v-if="detailTab === 'request'">
              <div class="text-xs text-[#71717a] mb-2">
                大小: {{ Math.round((detail.request_size_bytes || 0) / 1024) }} KB
                <span v-if="detail.request_truncated" class="text-[#f59e0b]">· ⚠️ 已截断 (超 100KB 只存头尾摘要)</span>
              </div>
              <pre class="text-xs bg-[#0f172a] text-[#e2e8f0] rounded p-3 overflow-auto max-h-[70vh] font-mono">{{ prettyJson(detail.request_body) }}</pre>
            </template>

            <template v-if="detailTab === 'response'">
              <div class="text-xs text-[#71717a] mb-2">
                大小: {{ Math.round((detail.response_size_bytes || 0) / 1024) }} KB
                <span v-if="detail.response_truncated" class="text-[#f59e0b]">· ⚠️ 已截断</span>
                <span v-if="detail.is_stream" class="ml-2">· 📡 流式（聚合后的最终文本）</span>
              </div>
              <div v-if="detail.response_text" class="mb-3">
                <div class="text-xs font-medium text-[#71717a] uppercase mb-1">最终文本</div>
                <pre class="text-xs bg-[#fafafa] border border-[#e5e7eb] rounded p-3 overflow-auto max-h-[40vh] whitespace-pre-wrap">{{ detail.response_text }}</pre>
              </div>
              <div v-if="detail.response_body">
                <div class="text-xs font-medium text-[#71717a] uppercase mb-1">完整响应体</div>
                <pre class="text-xs bg-[#0f172a] text-[#e2e8f0] rounded p-3 overflow-auto max-h-[40vh] font-mono">{{ prettyJson(detail.response_body) }}</pre>
              </div>
            </template>

            <template v-if="detailTab === 'raw'">
              <pre class="text-xs bg-[#0f172a] text-[#e2e8f0] rounded p-3 overflow-auto max-h-[80vh] font-mono">{{ prettyJson(detail) }}</pre>
            </template>
          </div>
        </template>
      </div>
    </div>
  </div>
</template>
