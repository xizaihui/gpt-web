          </tr>
        </tbody>
      </table>

      <div v-if="total > 0" class="flex items-center justify-between px-4 py-2 border-t border-[#e5e7eb] text-xs text-[#71717a]">
        <div>共 {{ total }} 条 · 第 {{ page }}/{{ totalPages }} 页</div>
        <div class="flex items-center gap-1">
          <button class="px-2 py-1 border border-[#e5e7eb] rounded hover:bg-[#f4f4f5] disabled:opacity-30" :disabled="page <= 1" @click="goPage(page - 1)">‹</button>
          <span class="px-2">{{ page }}</span>
          <button class="px-2 py-1 border border-[#e5e7eb] rounded hover:bg-[#f4f4f5] disabled:opacity-30" :disabled="page >= totalPages" @click="goPage(page + 1)">›</button>
